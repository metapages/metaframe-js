
@_help:
    just --list --unsorted

build:
    #!/usr/bin/env bash
    set -euo pipefail
    python3 -m venv .venv
    source .venv/bin/activate
    pip install -q -r requirements.txt
    # Get version from pyproject.toml and patch notebook for JupyterLite (micropip can't use local paths)
    VERSION=$(python3 -c "import tomllib; print(tomllib.load(open('../../python/pyproject.toml','rb'))['project']['version'])")
    rm -rf _output .jupyterlite.doit.db
    mkdir -p _build_content
    cp -r content/* _build_content/
    sed -i '' "s|%pip install ../../python|%pip install metaframe-widget==${VERSION}|g" _build_content/metaframe_demo.ipynb
    jupyter lite build --contents _build_content --output-dir _output
    rm -rf _build_content
    rm -rf ../../docs/public/jupyterlite
    cp -r _output ../../docs/public/jupyterlite

# Serve the JupyterLite site locally at http://localhost:8000
serve: build (open "http://localhost:8733")
    cd _output && python3 -m http.server 8733

open url:
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ "$OSTYPE" == "linux-gnu"* ]]; then
      xdg-open {{url}}
    elif [[ "$OSTYPE" == "darwin"* ]]; then
      open {{url}}
    fi
